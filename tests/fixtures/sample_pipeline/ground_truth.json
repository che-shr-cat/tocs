                {"target": "mod_a.py", "type": "REGISTRY_WIRES"},
                {"target": "mod_b.py", "type": "REGISTRY_WIRES"},
                {"target": "mod_c.py", "type": "REGISTRY_WIRES"},
                {"target": "mod_d.py", "type": "REGISTRY_WIRES"}
            ]
        },
        "mod_a.py": {
            "filepath": "mod_a.py",
            "purpose": "Pipeline stage: ingestion and parsing of raw input records",
            "exports": ["IngestStage"],
            "edges": [
                {"target": "base.py", "type": "IMPORTS"},
                {"target": "models.py", "type": "IMPORTS"},
                {"target": "mod_b.py", "type": "DATA_FLOWS_TO"}
            ]
        },
        "mod_b.py": {
            "filepath": "mod_b.py",
            "purpose": "Pipeline stage: validation, quality checks, sets is_validated flag",
            "exports": ["ValidateStage"],
            "edges": [
                {"target": "base.py", "type": "IMPORTS"},
                {"target": "models.py", "type": "IMPORTS"},
                {"target": "helpers.py", "type": "IMPORTS"},
                {"target": "helpers.py", "type": "CALLS_API"},
                {"target": "mod_c.py", "type": "DATA_FLOWS_TO"}
            ]
        },
        "mod_c.py": {
            "filepath": "mod_c.py",
            "purpose": "Pipeline stage: enrichment with external lookups (requires validated input)",
            "exports": ["EnrichStage"],
            "edges": [
                {"target": "base.py", "type": "IMPORTS"},
                {"target": "models.py", "type": "IMPORTS"},
                {"target": "mod_d.py", "type": "DATA_FLOWS_TO"}
            ]
        },
        "mod_d.py": {
            "filepath": "mod_d.py",
            "purpose": "Pipeline stage: final output formatting and serialization",
