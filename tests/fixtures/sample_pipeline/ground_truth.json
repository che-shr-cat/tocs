    "invariants": [
        {
            "id": "inv-001",
            "type": "DATAFLOW",
            "description": "Data must pass through mod_b (validation, sets is_validated=True) before reaching mod_c (enrichment, requires is_validated=True)",
            "structured": {
                "type": "VALIDATION_CHAIN",
                "src": "mod_b.py",
                "dst": "mod_c.py",
                "via": "is_validated"
            },
            "involved_modules": ["mod_b.py", "mod_c.py"],
            "rationale": "mod_c checks is_validated and raises ValueError in strict mode if records were not validated by mod_b first",
            "evidence_types": ["test", "documentation"],
            "evidence_locations": ["test_boundaries.py", "mod_c.py"]
        },
        {
            "id": "inv-002",
            "type": "BOUNDARY",
            "description": "Pipeline stages (mod_a, mod_b, mod_c, mod_d) must not import each other directly — they communicate only via the runner/registry mechanism",
            "structured": {
                "type": "FORBIDDEN_EDGE",
                "pattern": "no stage-to-stage imports"
            },
            "involved_modules": ["mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py"],
            "rationale": "Direct imports between stages would bypass the pipeline contract and create hidden ordering dependencies",
            "evidence_types": ["test", "structural"],
            "evidence_locations": ["test_boundaries.py"]
        },
        {
            "id": "inv-003",
            "type": "INTERFACE",
            "description": "All pipeline stages implement StageBase ABC with process(records, config) -> list[Record]",
            "structured": {
                "type": "INTERFACE_ONLY",
                "via": "base.py"
            },
            "involved_modules": ["base.py", "mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py"],
            "rationale": "A uniform interface lets the runner chain stages generically without knowing concrete types",
            "evidence_types": ["structural"],
            "evidence_locations": ["base.py", "mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py"]
        },
        {
            "id": "inv-004",
            "type": "BOUNDARY",
            "description": "No stage or helper may import runner.py (no reverse dependency on orchestrator)",
            "structured": {
                "type": "FORBIDDEN_EDGE",
                "dst": "runner.py"
            },
            "involved_modules": ["runner.py", "mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py", "helpers.py"],
            "rationale": "The orchestrator depends on stages, not the reverse; circular deps would break independent testability",
            "evidence_types": ["structural"],
            "evidence_locations": ["runner.py"]
        },
        {
            "id": "inv-005",
            "type": "INVARIANT",
            "description": "Pipeline stage ordering is defined in pipeline_config.json, not in code — the registry reads config at runtime via importlib",
            "structured": {
                "type": "VALIDATION_CHAIN",
                "src": "registry.py",
                "via": "pipeline_config.json"
            },
            "involved_modules": ["registry.py", "mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py"],
            "rationale": "Externalizing stage wiring to config makes the pipeline reconfigurable without code changes",
            "evidence_types": ["structural", "documentation"],
            "evidence_locations": ["registry.py", "pipeline_config.json"]
        },
        {
            "id": "inv-006",
            "type": "PURPOSE",
            "description": "legacy.py is dead code — no active module imports or references it",
            "structured": {
                "type": "FORBIDDEN_EDGE",
                "dst": "legacy.py",
                "pattern": "no incoming edges"
            },
            "involved_modules": ["legacy.py"],
            "rationale": "Kept for backward compatibility with historical data but intentionally excluded from the active pipeline",
            "evidence_types": ["documentation", "structural"],
            "evidence_locations": ["legacy.py"]
        }
    ],
    "design_rationales": [
        {
            "id": "dr-001",
            "question": "Why does mod_c reject records without is_validated=True instead of just processing them?",
            "answer": "Data integrity guarantee: enrichment lookups assume validated, well-formed input. Processing unvalidated records could produce corrupt enrichment joins.",
            "affected_modules": ["mod_b.py", "mod_c.py"],
            "downstream_effects": [
                "Skipping validation would cause mod_c to raise ValueError in strict mode",
                "In non-strict mode, unvalidated records are silently dropped, causing data loss"
            ]
        },
        {
            "id": "dr-002",
            "question": "Why are stages wired via pipeline_config.json and importlib instead of direct imports in runner.py?",
            "answer": "Externalizing stage wiring to config enables reordering, adding, or removing stages without modifying Python code. It also decouples the runner from concrete stage classes.",
            "affected_modules": ["runner.py", "registry.py", "mod_a.py", "mod_b.py", "mod_c.py", "mod_d.py"],
            "downstream_effects": [
                "Direct imports would make the runner tightly coupled to specific stages",
                "Reordering stages would require code changes instead of config changes",
                "Static analysis tools cannot follow dynamic importlib-based wiring"
            ]
        },
        {
            "id": "dr-003",
            "question": "Why is legacy.py kept in the repository if nothing uses it?",
            "answer": "Backward compatibility: historical data in the old LegacyRecord format may need reprocessing. Removing it would lose the conversion logic.",
            "affected_modules": ["legacy.py"],
            "downstream_effects": [
                "Removing legacy.py breaks ability to reprocess historical v0 data",
                "No active code would break since nothing imports legacy.py"
            ]
        },
        {
            "id": "dr-004",
            "question": "Why does mod_b import helpers.py instead of implementing checksum inline?",
            "answer": "compute_checksum is a general-purpose utility that could be reused. Isolating it in helpers.py keeps stage logic focused on validation rules.",
            "affected_modules": ["mod_b.py", "helpers.py"],
            "downstream_effects": [
                "Changing the checksum algorithm only requires editing helpers.py",
                "Other stages or tools could reuse compute_checksum without depending on mod_b"
            ]
        }
    ],
